# ================================================================
#  Content Agent — Environment Variables Template
#
#  HOW TO USE:
#  1. Copy this file and rename the copy to .env
#  2. Fill in your real values in .env
#  3. NEVER commit .env to GitHub — it contains your secrets
#  4. This .env.example file IS safe to commit (it has no real values)
#
#  YOU ONLY NEED 3 TOKENS TO START:
# ================================================================


# ── TOKEN 1: HuggingFace ────────────────────────────────────────
#
#  What it does: Powers the AI that writes your blog posts.
#                Uses Mistral-7B-Instruct model (free tier).
#
#  How to get it (2 min):
#    1. Go to https://huggingface.co → Sign Up (free)
#    2. Go to https://huggingface.co/settings/tokens
#    3. Click "New token" → Name: content-agent → Role: Read
#    4. Click "Generate token" → Copy it
#
#  Looks like: hf_aBcDeFgHiJkLmNoPqRsTuVwXyZ123456
#
HF_TOKEN=your_huggingface_token_here


# ── TOKEN 2: Telegram Bot Token ─────────────────────────────────
#
#  What it does: Sends your generated blog draft to your Telegram.
#                Also lets you send /topic commands to the bot
#                to tell the agent what to write about next.
#
#  How to get it (3 min):
#    1. Open Telegram → search @BotFather → open it
#    2. Send: /newbot
#    3. Choose a name (e.g. "Content Agent")
#    4. Choose a username ending in bot (e.g. "mywriter_bot")
#    5. BotFather gives you a token → copy it
#
#  Looks like: 7123456789:AAFabcDEFghiJKLmnoPQRstUVwxYZ-abc123
#
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here


# ── TOKEN 3: Telegram Chat ID ────────────────────────────────────
#
#  What it does: Tells the bot which chat to send your drafts to.
#                This is YOUR personal chat ID.
#
#  How to get it (2 min):
#    1. Open Telegram → find your new bot → send it any message
#    2. Open this URL in browser (replace YOUR_TOKEN):
#       https://api.telegram.org/botYOUR_TOKEN/getUpdates
#    3. Find "chat": {"id": 987654321} → copy that number
#
#  Looks like: 987654321  (just a number, no letters)
#
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ================================================================
#  OPTIONAL — Add these later when ready to publish
# ================================================================

# LinkedIn credentials (for LinkedIn post automation via Playwright)
# LINKEDIN_EMAIL=your@email.com
# LINKEDIN_PASSWORD=your_linkedin_password